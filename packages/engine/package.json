{
  "name": "@vimp/engine",
  "version": "0.1.0",
  "description": "VIMP Engine — движок-приложение (мастер, P2P-транспорт, Worker-хост, мета, MVC-каркас клиента)",
  "type": "module",
  "main": "src/master/main.js",
  "exports": {
    "./lib/*": "./src/lib/*",
    "./config/*": "./src/config/*",
    "./host/*": "./src/host/*"
  },
  "files": [
    "src/lib",
    "src/config",
    "src/host"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "dev": "NODE_ENV=development nodemon src/master/main.js -w src/master -w src/lib -w src/config",
    "start": "NODE_ENV=production node --env-file ../../.env src/master/main.js",
    "build": "vite build"
  },
  "dependencies": {
    "@vimp/tanks": "^0.1.0",
    "express": "^5.1.0",
    "uuid": "^13.0.0",
    "vite-express": "^0.21.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "howler": "^2.2.4",
    "nodemon": "^3.1.10",
    "pixi.js": "^8.14.0",
    "vite": "^7.1.11",
    "vite-plugin-pug": "^0.4.1"
  }
}
