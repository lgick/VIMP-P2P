div#lobby
  div#lobby-panel
    h2= 'VIMP P2P'
    div#lobby-create
      input#lobby-name(type='text', placeholder='Server name…', maxlength='30')
      //- скрыт, пока каталог мастера содержит одну игру (Этап 6.3, PLAN.md §6)
      select#lobby-game(style='display:none')
      label
        span= 'Max players'
        input#lobby-max-players(type='number', min='1')
      label
        span= 'Round time (s)'
        input#lobby-round-time(type='number', min='1')
      label
        span= 'Map time (s)'
        input#lobby-map-time(type='number', min='1')
      label
        input#lobby-friendly-fire(type='checkbox')
        span= 'Friendly fire'
      label
        span= 'Map'
        select#lobby-map
      button#lobby-host(type='button')= 'Create server'
    input#lobby-search(type='text', placeholder='Search servers…')
    ul#lobby-list
    p#lobby-empty= 'No servers available'
    button#lobby-more(type='button')= 'Load more'
