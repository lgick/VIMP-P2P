{
  "name": "vimp",
  "version": "2.0",
  "author": "lgick",
  "license": "MIT",
  "private": false,
  "description": "game",
  "homepage": "https://github.com/lgick/VIMP-P2P#readme",
  "bugs": {
    "url": "https://github.com/lgick/VIMP-P2P/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/lgick/VIMP-P2P.git"
  },
  "type": "module",
  "main": "src/master/main.js",
  "workspaces": [
    "packages/engine",
    "games/tanks"
  ],
  "scripts": {
    "dev": "NODE_ENV=development nodemon src/master/main.js -w src/master -w src/lib -w src/config -w games/tanks/src",
    "start": "NODE_ENV=production node --env-file .env src/master/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "npm run core:build:web && npm run build:app",
    "build:app": "npm run audio:process && vite build",
    "audio:process": "node scripts/process-audio.js",
    "core:build": "npm run core:build:web && npm run core:build:node",
    "core:build:web": "wasm-pack build core --release --target web --out-dir pkg-web",
    "core:build:node": "wasm-pack build core --release --target nodejs --out-dir pkg-node",
    "core:test": "cargo test --manifest-path core/Cargo.toml",
    "maps:export": "node scripts/export-maps.js"
  },
  "dependencies": {
    "express": "^5.1.0",
    "howler": "^2.2.4",
    "pixi.js": "^8.14.0",
    "uuid": "^13.0.0",
    "vite-express": "^0.21.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-consecutive-caps": "^1.2.0",
    "globals": "^16.2.0",
    "happy-dom": "^20.10.6",
    "nodemon": "^3.1.10",
    "vite": "^7.1.11",
    "vite-plugin-pug": "^0.4.1",
    "vitest": "^4.1.9"
  }
}
